{
  "manifest_version": 3,
  "name": "知乎本地屏蔽助手",
  "version": "0.1.0",
  "description": "本地标注、折叠知乎黑名单用户，并尽力同步知乎官方拉黑。",
  "permissions": [
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.zhihu.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "action": {
    "default_popup": "src/pages/popup.html",
    "default_title": "知乎本地屏蔽助手",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "options_page": "src/pages/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.zhihu.com/*"
      ],
      "js": [
        "src/content/zhihu-hook-injector.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.zhihu.com/*"
      ],
      "js": [
        "src/common.js",
        "src/content/zhihu-content.js"
      ],
      "css": [
        "src/content/zhihu-content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/zhihu-hook-injector.js",
        "src/content/zhihu-page-hook.js"
      ],
      "matches": [
        "https://www.zhihu.com/*"
      ]
    }
  ]
}
